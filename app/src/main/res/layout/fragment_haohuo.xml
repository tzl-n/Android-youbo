<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- 好货页面顶部搜索栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@android:color/white"
        android:elevation="4dp">
        
        <!-- 顶部状态栏占位 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="24dp"
            android:background="@android:color/white" />
        
        <!-- 搜索区域 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">
            
            <!-- 标题：上图下文布局 -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginEnd="16dp">
                
                <!-- 上方图片 -->
                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/asahh"
                    android:scaleType="centerInside"
                    android:contentDescription="好货图标" />
                
                <!-- 下方文字 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="新手教程"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
            
            <!-- 搜索框 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:background="@drawable/bg_search_bar_douyin_style"
                android:gravity="center_vertical">
                
                <!-- 搜索图标 -->
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginStart="12dp"
                    android:src="@drawable/ic_search_modern"
                    app:tint="#999999" />
                
                <!-- 搜索输入框 -->
                <EditText
                    android:id="@+id/search_input"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@null"
                    android:hint="请输入搜索关键词"
                    android:textSize="14sp"
                    android:textColor="#333333"
                    android:textColorHint="#999999"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:inputType="text"
                    android:imeOptions="actionSearch"
                    android:singleLine="true" />
                
                <!-- 搜索按钮 -->
                <Button
                    android:id="@+id/btn_search"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_marginEnd="8dp"
                  android:backgroundTint="#181E26"
                    android:text="搜索"
                    android:textColor="#DAFFB85C"
                    android:textSize="14sp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- 大家都在看区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@android:color/white"
        android:padding="12dp"
        android:gravity="center_vertical">
        
        <!-- 火焰图标 -->
        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_fire"
            android:layout_marginEnd="8dp"
            android:contentDescription="热门" />
        
        <!-- 大家都在看标题 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="大家都在看"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginEnd="8dp" />
        
        <!-- 左滑更多提示 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="左滑更多"
            android:textSize="14sp"
            android:textColor="#999999" />
    </LinearLayout>

    <!-- 商品瀑布流 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingHorizontal="4dp"
        android:paddingBottom="8dp" />
</LinearLayout>